<Server port="<%= $shutdown_port %>" shutdown="SHUTDOWN">
  <Service name="Catalina">
    <Connector port="<%= $connector_port %>"
               protocol="HTTP/1.1"
               connectionTimeout="20000"
               redirectPort="<%= $redirect_port %>" />
    <Engine name="Catalina" defaultHost="localhost">
      <Host name="localhost"
            appBase="webapps"
            unpackWARs="true"
            autoDeploy="true" />
    </Engine>
  </Service>
</Server>
